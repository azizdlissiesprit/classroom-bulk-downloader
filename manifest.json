{
  "manifest_version": 3,
  "name": "Classroom Bulk Downloader",
  "version": "1.0.0",
  "description": "Scan the current Google Classroom (or Drive) page and download the files you pick — in one click, no extra windows.",
  "permissions": ["downloads", "scripting", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Classroom Bulk Downloader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
